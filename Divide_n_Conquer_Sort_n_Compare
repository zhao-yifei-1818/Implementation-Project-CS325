Algorithm 4 Divide and Conquer Compare"""


def gen_array(size):
    arr = []

    for i in range(size):
        num = random.randint(-100, 100)
        arr.append(num)

    return arr


def get_size():
    size = int(input("Enter array size: "))
    return size


def solve(arr, start, end):

    if start == end:
        return (arr[start], start, end)

    mid = (start + end) // 2

    left_result = solve(arr, start, mid)
    right_result = solve(arr, mid + 1, end)

    # Algorithm 4 cross case:
    # closest subarray crosses the middle:
    # suffix from left half + prefix from right half

    values = []

    # all suffix sums from left half
    suffix_sum = 0
    for i in range(mid, start - 1, -1):
        suffix_sum += arr[i]
        values.append((suffix_sum, "S", i, mid))

    # all negative prefix sums from right half
    prefix_sum = 0
    for j in range(mid + 1, end + 1):
        prefix_sum += arr[j]
        values.append((-prefix_sum, "P", mid + 1, j))

    # sort all suffix sums and negative prefix sums
    values.sort(key=lambda x: x[0])

    best_cross_sum = float("inf")
    best_cross_start = 0
    best_cross_end = 0

    # compare adjacent values only
    for k in range(len(values) - 1):
        first = values[k]
        second = values[k + 1]

        # one must be suffix and one must be prefix
        if first[1] != second[1]:

            if first[1] == "S":
                suffix = first
                prefix = second
            else:
                suffix = second
                prefix = first

            # suffix value is real suffix sum
            # prefix value was stored as negative prefix sum
            # so real cross sum = suffix_sum - negative_prefix_sum
            total = suffix[0] - prefix[0]

            if abs(total) < abs(best_cross_sum):
                best_cross_sum = total
                best_cross_start = suffix[2]
                best_cross_end = prefix[3]

    cross_result = (
        best_cross_sum,
        best_cross_start,
        best_cross_end
    )

    best_result = left_result

    if abs(right_result[0]) < abs(best_result[0]):
        best_result = right_result

    if abs(cross_result[0]) < abs(best_result[0]):
        best_result = cross_result

    return best_result


def algorithm4(arr):
    if len(arr) == 0:
        return None

    best_sum, start, end = solve(arr, 0, len(arr) - 1)

    return best_sum, arr[start:end + 1]


if __name__ == "__main__":

    # time take for 100-900, average from 10 tries
    for size in range(100, 1000, 100):
        total_time = 0
        for i in range(10):
            arr = gen_array(size)
            clock_start = time.time()
            algorithm4(arr)
            clock_end = time.time()
            elapsed_time = clock_end - clock_start
            total_time += elapsed_time
        # average of 10 runs
        average_time = total_time / 10
